import * as React from "react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Textarea } from "@/components/ui/textarea";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Activity, Heart, Droplet, Wind, Gauge, Navigation } from "lucide-react";
import type { FallDetectionLog } from "@/Entities/FallDetectionLog";

type Props = {
  onSubmit: (data: FallDetectionLog) => void;
  initialData?: Partial<FallDetectionLog>;
  isLoading?: boolean;
};

export default function LogForm({ onSubmit, initialData, isLoading }: Props) {
  const [formData, setFormData] = React.useState({
    distance: initialData?.distance?.toString() ?? "",
    pressure: (initialData?.pressure ?? 1).toString(),
    hrv: initialData?.hrv?.toString() ?? "",
    sugar_level: initialData?.sugar_level?.toString() ?? "",
    spo2: initialData?.spo2?.toString() ?? "",
    accelerometer: (initialData?.accelerometer ?? 0).toString(),
    decision: (initialData?.decision ?? 0).toString(),
    notes: initialData?.notes ?? "",
    measurement_date:
      initialData?.measurement_date ??
      new Date().toISOString().slice(0, 16), // YYYY-MM-DDTHH:mm
  });

  function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    const payload: FallDetectionLog = {
      id: (crypto as any).randomUUID?.() ?? String(Math.random()),
      distance: Number(formData.distance),
      pressure: Number(formData.pressure) as any,
      hrv: Number(formData.hrv),
      sugar_level: Number(formData.sugar_level),
      spo2: Number(formData.spo2),
      accelerometer: Number(formData.accelerometer) as any,
      decision: Number(formData.decision) as any,
      notes: formData.notes?.trim() || "",
      measurement_date: formData.measurement_date, // already in datetime-local format
    };
    onSubmit(payload);
  }

  return (
    <form onSubmit={handleSubmit} className="space-y-6">
      <Card className="border-teal-100 bg-white/80 backdrop-blur-sm">
        <CardHeader className="border-b border-teal-50 pb-4">
          <CardTitle className="flex items-center gap-2 text-xl">
            <Activity className="w-6 h-6 text-teal-600" />
            Sensor Measurements
          </CardTitle>
        </CardHeader>
        <CardContent className="pt-6">
          <div className="grid md:grid-cols-2 gap-6">
            <Field label="Distance (m)" icon={<Navigation className="w-4 h-4 text-blue-600" />}>
              <Input
                type="number"
                step="0.001"
                inputMode="decimal"
                value={formData.distance}
                onChange={(e) => setFormData({ ...formData, distance: e.target.value })}
                placeholder="e.g., 25.54"
                required
              />
            </Field>

            <Field label="Pressure Applied" icon={<Gauge className="w-4 h-4 text-red-600" />}>
              <Select
                value={formData.pressure}
                onValueChange={(pressure) => setFormData({ ...formData, pressure })}
              >
                <SelectTrigger><SelectValue placeholder="Select pressure" /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="0">0 - Low</SelectItem>
                  <SelectItem value="1">1 - Medium</SelectItem>
                  <SelectItem value="2">2 - High</SelectItem>
                </SelectContent>
              </Select>
            </Field>

            <Field label="Heart Rate Variability (ms)" icon={<Heart className="w-4 h-4 text-pink-600" />}>
              <Input
                type="number"
                step="0.001"
                inputMode="decimal"
                value={formData.hrv}
                onChange={(e) => setFormData({ ...formData, hrv: e.target.value })}
                placeholder="e.g., 101.396"
                required
              />
            </Field>

            <Field label="Blood Sugar (mg/dL)" icon={<Droplet className="w-4 h-4 text-amber-600" />}>
              <Input
                type="number"
                step="0.01"
                inputMode="decimal"
                value={formData.sugar_level}
                onChange={(e) => setFormData({ ...formData, sugar_level: e.target.value })}
                placeholder="e.g., 61.08"
                required
              />
            </Field>

            <Field label="Blood Oxygen SpO₂ (%)" icon={<Wind className="w-4 h-4 text-cyan-600" />}>
              <Input
                type="number"
                step="0.01"
                inputMode="decimal"
                value={formData.spo2}
                onChange={(e) => setFormData({ ...formData, spo2: e.target.value })}
                placeholder="e.g., 87.77"
                required
              />
            </Field>

            <Field label="Accelerometer" icon={<Activity className="w-4 h-4 text-purple-600" />}>
              <Select
                value={formData.accelerometer}
                onValueChange={(accelerometer) => setFormData({ ...formData, accelerometer })}
              >
                <SelectTrigger><SelectValue placeholder="Choose…" /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="0">0 - No Acceleration</SelectItem>
                  <SelectItem value="1">1 - Acceleration Detected</SelectItem>
                </SelectContent>
              </Select>
            </Field>
          </div>
        </CardContent>
      </Card>

      <Card className="border-teal-100 bg-white/80 backdrop-blur-sm">
        <CardHeader className="border-b border-teal-50 pb-4">
          <CardTitle className="text-xl">Assessment & Notes</CardTitle>
        </CardHeader>
        <CardContent className="pt-6 space-y-6">
          <div className="space-y-2">
            <Label>Fall Detection Decision</Label>
            <Select
              value={formData.decision}
              onValueChange={(decision) => setFormData({ ...formData, decision })}
            >
              <SelectTrigger><SelectValue placeholder="Select decision" /></SelectTrigger>
              <SelectContent>
                <SelectItem value="0">0 - Safe</SelectItem>
                <SelectItem value="1">1 - Warning</SelectItem>
                <SelectItem value="2">2 - Fall Detected</SelectItem>
              </SelectContent>
            </Select>
          </div>

          <div className="space-y-2">
            <Label>Measurement Date & Time</Label>
            <Input
              type="datetime-local"
              value={formData.measurement_date}
              onChange={(e) => setFormData({ ...formData, measurement_date: e.target.value })}
              required
            />
          </div>

          <div className="space-y-2">
            <Label>Additional Notes</Label>
            <Textarea
              value={formData.notes}
              onChange={(e) => setFormData({ ...formData, notes: e.target.value })}
              className="min-h-24"
              placeholder="Add any relevant observations or context…"
            />
          </div>
        </CardContent>
      </Card>

      <Button
        type="submit"
        disabled={isLoading}
        className="w-full bg-gradient-to-r from-teal-500 to-cyan-600"
      >
        {isLoading ? "Saving..." : initialData ? "Update Log" : "Save Log"}
      </Button>
    </form>
  );
}

function Field({ label, icon, children }: { label: string; icon?: React.ReactNode; children: React.ReactNode }) {
  return (
    <div className="space-y-2">
      <Label className="flex items-center gap-2">{icon}{label}</Label>
      {children}
    </div>
  );
}
