import React, { useState } from "react";
import { base44 } from "@/api/base44Client";
import { useQuery } from "@tanstack/react-query";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { TrendingUp, TrendingDown, Activity, Heart, Droplet } from "lucide-react";
import MetricCard from "../components/logs/MetricCard";
import { format, startOfMonth, endOfMonth } from "date-fns";

export default function MonthlyAnalytics() {
  const currentDate = new Date();
  const [selectedMonth, setSelectedMonth] = useState(format(currentDate, "yyyy-MM"));

  const { data: logs, isLoading } = useQuery({
    queryKey: ['fallLogs', selectedMonth],
    queryFn: async () => {
      const allLogs = await base44.entities.FallDetectionLog.list("-measurement_date");
      return allLogs.filter(log => {
        const logMonth = format(new Date(log.measurement_date), "yyyy-MM");
        return logMonth === selectedMonth;
      });
    },
    initialData: [],
  });

  const calculateAverage = (field) => {
    if (logs.length === 0) return 0;
    return (logs.reduce((sum, log) => sum + (log[field] || 0), 0) / logs.length).toFixed(2);
  };

  const countByDecision = () => {
    return logs.reduce((acc, log) => {
      acc[log.decision] = (acc[log.decision] || 0) + 1;
      return acc;
    }, {});
  };

  const decisionCounts = countByDecision();

  const months = Array.from({ length: 12 }, (_, i) => {
    const date = new Date(currentDate.getFullYear(), currentDate.getMonth() - i, 1);
    return format(date, "yyyy-MM");
  });

  return (
    <div className="min-h-screen p-4 md:p-8">
      <div className="max-w-7xl mx-auto">
        <div className="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
          <div>
            <h1 className="text-4xl font-bold text-slate-900 mb-2">Monthly Analytics</h1>
            <p className="text-slate-600">Aggregated health metrics and trends</p>
          </div>
          <Select value={selectedMonth} onValueChange={setSelectedMonth}>
            <SelectTrigger className="w-48 border-teal-200">
              <SelectValue />
            </SelectTrigger>
            <SelectContent>
              {months.map((month) => (
                <SelectItem key={month} value={month}>
                  {format(new Date(month), "MMMM yyyy")}
                </SelectItem>
              ))}
            </SelectContent>
          </Select>
        </div>

        <div className="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <Card className="p-6 bg-gradient-to-br from-teal-500 to-cyan-600 text-white border-0 shadow-xl">
            <div className="flex items-center justify-between mb-4">
              <Activity className="w-8 h-8 opacity-80" />
              <div className="text-right">
                <p className="text-sm font-medium opacity-90">Total Logs</p>
                <p className="text-4xl font-bold mt-1">{logs.length}</p>
              </div>
            </div>
            <p className="text-xs opacity-75">{format(new Date(selectedMonth), "MMMM yyyy")}</p>
          </Card>

          <Card className="p-6 bg-gradient-to-br from-green-500 to-emerald-600 text-white border-0 shadow-xl">
            <div className="flex items-center justify-between mb-4">
              <TrendingUp className="w-8 h-8 opacity-80" />
              <div className="text-right">
                <p className="text-sm font-medium opacity-90">No Falls</p>
                <p className="text-4xl font-bold mt-1">{decisionCounts["No Fall"] || 0}</p>
              </div>
            </div>
            <p className="text-xs opacity-75">Safe measurements</p>
          </Card>

          <Card className="p-6 bg-gradient-to-br from-amber-500 to-orange-600 text-white border-0 shadow-xl">
            <div className="flex items-center justify-between mb-4">
              <Activity className="w-8 h-8 opacity-80" />
              <div className="text-right">
                <p className="text-sm font-medium opacity-90">Warnings</p>
                <p className="text-4xl font-bold mt-1">{decisionCounts["Warning"] || 0}</p>
              </div>
            </div>
            <p className="text-xs opacity-75">Needs attention</p>
          </Card>

          <Card className="p-6 bg-gradient-to-br from-red-500 to-rose-600 text-white border-0 shadow-xl">
            <div className="flex items-center justify-between mb-4">
              <TrendingDown className="w-8 h-8 opacity-80" />
              <div className="text-right">
                <p className="text-sm font-medium opacity-90">Falls Detected</p>
                <p className="text-4xl font-bold mt-1">{decisionCounts["Fall Detected"] || 0}</p>
              </div>
            </div>
            <p className="text-xs opacity-75">Critical alerts</p>
          </Card>
        </div>

        <Card className="border-teal-100 bg-white/80 backdrop-blur-sm mb-8">
          <CardHeader className="border-b border-teal-50">
            <CardTitle className="text-2xl">Average Measurements</CardTitle>
          </CardHeader>
          <CardContent className="pt-6">
            <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              <MetricCard
                icon={Activity}
                label="Avg Distance"
                value={calculateAverage('distance')}
                unit="m"
                bgColor="bg-blue-500"
              />
              <MetricCard
                icon={Heart}
                label="Avg Pressure"
                value={calculateAverage('pressure')}
                unit="mmHg"
                bgColor="bg-red-500"
              />
              <MetricCard
                icon={Heart}
                label="Avg HRV"
                value={calculateAverage('hrv')}
                unit="ms"
                bgColor="bg-pink-500"
              />
              <MetricCard
                icon={Droplet}
                label="Avg Blood Sugar"
                value={calculateAverage('sugar_level')}
                unit="mg/dL"
                bgColor="bg-amber-500"
              />
              <MetricCard
                icon={Activity}
                label="Avg SpO2"
                value={calculateAverage('spo2')}
                unit="%"
                bgColor="bg-cyan-500"
              />
              <MetricCard
                icon={Activity}
                label="Avg Accelerometer"
                value={calculateAverage('accelerometer')}
                unit="m/s²"
                bgColor="bg-purple-500"
              />
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
  );
}